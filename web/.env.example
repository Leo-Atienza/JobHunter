DATABASE_URL=postgresql://user:pass@host.neon.tech/jobhunter?sslmode=require
CRON_SECRET=your-random-secret-here

# Auth.js (NextAuth v5) — required for user accounts
AUTH_SECRET=generate-with-npx-auth-secret
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

# Optional: AI summaries + resume extraction
GEMINI_API_KEY=your-gemini-api-key

# Optional: Firecrawl web search (free tier: 500 credits/month — firecrawl.dev)
FIRECRAWL_API_KEY=your-firecrawl-api-key

# Optional: Apify for JobBank.ca scraper (free tier: $5/month credits — apify.com)
APIFY_TOKEN=your-apify-api-token

# Optional: Adzuna job search (free tier — developer.adzuna.com)
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_API_KEY=your-adzuna-api-key

# Optional: Jooble job search (free tier — jooble.org/api/about)
JOOBLE_API_KEY=your-jooble-api-key
